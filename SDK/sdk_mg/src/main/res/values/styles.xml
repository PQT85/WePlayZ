    <style name="text_title_large">
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/mg_size_title_large</item>
    </style>

    <style name="text_title_medium">
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/mg_size_title_medium</item>
    </style>
    <style name="text_default">
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/mg_size_default</item>
    </style>

    <style name="item_text_menu">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="item_main_button">

        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/mg_bg_button_main_selector</item>
        <item name="android:paddingLeft">@dimen/padding_left_right_button</item>
        <item name="android:paddingRight">@dimen/padding_left_right_button</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:paddingTop">@dimen/mg_padding_top_bottom_button</item>
        <item name="android:paddingBottom">@dimen/mg_padding_top_bottom_button</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>

    </style>
    <style name="item_edittext_input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/mg_bg_input</item>
        <item name="android:paddingLeft">@dimen/padding_left_right_input_2</item>
        <item name="android:paddingRight">@dimen/padding_left_right_input_2</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:paddingTop">@dimen/mg_padding_top_bottom_input</item>
        <item name="android:paddingBottom">@dimen/mg_padding_top_bottom_input</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/colorTitle</item>
        <item name="android:textColorHint">@color/black_overlay</item>
        <item name="android:left">10dp</item>
        <item name="android:drawablePadding">7dp</item>
        <item name="android:maxHeight">40dp</item>
    </style>
    <style name="MainWhiteButton" parent="Theme.MaterialComponents">
        <item name="colorOnPrimary">@color/black_overlay</item>
        <item name="colorPrimary">@color/colorMgPrimary</item>
        <item name="colorOnSurface">@color/colorMgPrimary</item>
        <item name="android:textColor">@color/colorTitle</item>
    </style>

    <style name="WhiteGreyButton" parent="Theme.MaterialComponents">
        <item name="colorOnPrimary">@color/black_overlay</item>
        <item name="colorPrimary">@color/colorBackground</item>
        <item name="colorOnSurface">@color/colorMgPrimary</item>
        <item name="android:textColor">@color/black_overlay</item>
    </style>
</resources>