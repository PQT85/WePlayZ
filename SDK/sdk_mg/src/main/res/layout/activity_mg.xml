<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#88000000"
    tools:context=".MGActivity">
    <Button
        android:id="@+id/debug_mode"
        android:layout_width="50dp"
        android:layout_height="50dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_alignParentRight="true"
        android:background="@android:color/transparent"

        />
    <RelativeLayout



        android:gravity="center"
        android:id="@+id/activity_migame_llContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_height="@dimen/size_bg"
        android:layout_width="@dimen/size_bg"
        android:paddingTop="@dimen/mg_padding_top_bottom_master_content"
        android:paddingBottom="@dimen/mg_padding_top_bottom_master_content"
        android:paddingLeft="@dimen/mg_padding_left_right_master_content"
        android:paddingRight="@dimen/mg_padding_left_right_master_content"
        android:background="@drawable/mg_bg_radius"
        >

        <ProgressBar
            android:id="@+id/activity_mg_pgLoading"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:indeterminate="true"



             />
        <include layout="@layout/mg_main_account" android:id="@+id/activity_mg_layout_main_account" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_centerInParent="true"

            />


        <include layout="@layout/mg_fragment_login" android:id="@+id/activity_mg_layout_login" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            />

        <include layout="@layout/mg_fragment_register" android:id="@+id/activity_mg_layout_register" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            />

        <include layout="@layout/mg_fragment_sync_account" android:id="@+id/activity_mg_layout_sync_account" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            />

        <include layout="@layout/mg_fragment_forget_pass" android:id="@+id/activity_mg_layout_forget_pass" android:layout_width="match_parent" android:layout_height="match_parent"
             android:visibility="gone"

            android:layout_alignParentTop="true"


            />
    </RelativeLayout>


</androidx.constraintlayout.widget.ConstraintLayout>