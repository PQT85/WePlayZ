<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"

    >

    <include
        android:id="@+id/mg_fragment_sync_ll_back"
        layout="@layout/mg_fragment_layout_back" />
    <androidx.core.widget.NestedScrollView
        android:layout_below="@+id/mg_fragment_sync_ll_back"
        android:paddingLeft="@dimen/mg_padding_left_right_content"
        android:paddingRight="@dimen/mg_padding_left_right_content"
        android:layout_width="match_parent"
        android:foregroundGravity="center"
        android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/mg_fragment_sync_ll_input"
            android:layout_gravity="center|top"
            android:gravity="center|top"

            android:paddingLeft="@dimen/padding_left_right_input"
            android:paddingRight="@dimen/padding_left_right_input"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/text_title_large"

                android:text="@string/mg_fragment_sync_title_sync"
                android:layout_marginBottom="@dimen/mg_padding_top_bottom_button"
                />
<!--            <ImageView-->
<!--                android:visibility="gone"-->
<!--                android:layout_margin="4dp"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="@dimen/mg_height_logo_gg"-->
<!--                android:scaleType="fitCenter"-->

<!--                android:layout_gravity="center"-->
<!--                android:id="@+id/mg_fragment_sync_iv_logo"-->
<!--                />-->
            <EditText
                android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                android:paddingRight="50dp"
                style="@style/item_edittext_input"
                android:id="@+id/mg_fragment_sync_ed_account"
                android:drawableLeft="@drawable/user"
                android:hint="@string/mg_fragment_register_hint_acc"

                android:drawablePadding="5dp"
                />
            <RelativeLayout
                android:id="@+id/mg_fragment_sync_el_password"
                android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                >

                <EditText
                    style="@style/item_edittext_input"
                    android:paddingRight="50dp"
                    android:drawableLeft="@drawable/lock1"
                    android:id="@+id/mg_fragment_sync_ed_pass"
                    android:hint="@string/mg_fragment_register_hint_pass"
                    android:inputType="textPassword"
                    android:drawablePadding="5dp"
                    />
                <ImageView
                    android:padding="4dp"
                    android:id="@+id/mg_fragment_sync_iv_eye"
                    android:scaleType="fitCenter"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/invisible"
                    android:layout_width="40dp"
                    android:layout_alignTop="@+id/mg_fragment_sync_ed_pass"
                    android:layout_alignBottom="@+id/mg_fragment_sync_ed_pass"
                    android:layout_height="match_parent"/>
            </RelativeLayout>
            <RelativeLayout
                    android:id="@+id/mg_fragment_sync_el_confirmPassword"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"


                    >

                    <EditText

                        style="@style/item_edittext_input"
                        android:paddingRight="50dp"

                        android:id="@+id/mg_fragment_sync_ed_Confirmpass"
                        android:drawableLeft="@drawable/lock1"
                        android:hint="@string/mg_fragment_register_hint_pass_again"
                        android:inputType="textPassword"
                        android:drawablePadding="5dp"
                        />
                    <ImageView
                        android:scaleType="fitCenter"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/invisible"
                        android:layout_width="40dp"
                        android:padding="4dp"
                        android:id="@+id/mg_fragment_sync_iv_eye_confirm"
                        android:layout_alignTop="@+id/mg_fragment_sync_ed_Confirmpass"
                        android:layout_alignBottom="@+id/mg_fragment_sync_ed_Confirmpass"
                        android:layout_height="match_parent"/>
                </RelativeLayout>

            <TextView
                    android:visibility="gone"
                    android:paddingLeft="10dp"
                    android:paddingTop="10dp"
                    android:paddingRight="10dp"
                    android:id="@+id/mg_fragment_sync_tv_info_user"
