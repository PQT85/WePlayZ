                        android:id="@+id/mg_fragment_sync_ed_phone"
                        android:drawableLeft="@drawable/phone"
                        android:hint="@string/mg_fragment_register_hint_phone_number"
                        android:inputType="phone"
                        android:drawablePadding="5dp"
