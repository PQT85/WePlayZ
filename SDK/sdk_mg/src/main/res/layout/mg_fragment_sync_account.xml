                    android:id="@+id/mg_fragment_sync_rg_gender"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_edittext_input"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"

                    android:paddingLeft="8dp"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:textColor="@color/black_overlay"
                        android:id="@+id/mg_fragment_sync_rdo_male"
                        android:checked="true"
                        android:buttonTint="@color/colorTitle"
                        android:text="@string/mg_fragment_register_hint_gender_male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <RadioButton
                        android:textColor="@color/black_overlay"
                        android:layout_marginLeft="3dp"
                        android:id="@+id/mg_fragment_sync_rdo_female"
                        android:buttonTint="@color/colorTitle"
                        android:text="@string/mg_fragment_register_hint_gender_female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <RadioButton
                        android:textColor="@color/black_overlay"
                        android:layout_marginLeft="3dp"
                        android:id="@+id/mg_fragment_sync_rdo_other"
                        android:buttonTint="@color/colorTitle"
                        android:text="@string/mg_fragment_register_hint_gender_other"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </RadioGroup>
                <vn.mgjsc.sdk.views.EditViewClickDrawable
                    android:paddingRight="50dp"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_edittext_input"
