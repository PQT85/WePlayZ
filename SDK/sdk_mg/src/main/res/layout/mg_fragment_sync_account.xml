                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    android:paddingRight="50dp"
                    style="@style/item_edittext_input"
                    android:id="@+id/mg_fragment_sync_ed_fullname"
                    android:drawableLeft="@drawable/user"
                    android:hint="@string/mg_fragment_register_hint_name"

                    android:drawablePadding="5dp"
                    />
