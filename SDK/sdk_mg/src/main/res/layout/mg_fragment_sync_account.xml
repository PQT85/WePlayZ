                    android:id="@+id/mg_fragment_sync_ed_dob"
                    android:drawableLeft="@drawable/date"
                    android:drawableRight="@drawable/date"
                    android:hint="@string/mg_fragment_register_hint_dob"/>

                <EditText
                    android:paddingRight="50dp"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_edittext_input"
                    android:id="@+id/mg_fragment_sync_ed_id"
                    android:drawableLeft="@drawable/cmnd"
                    android:hint="@string/mg_fragment_register_hint_persional_id"/>

                <vn.mgjsc.sdk.views.EditViewClickDrawable
                    android:paddingRight="50dp"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_edittext_input"
                    android:id="@+id/mg_fragment_sync_ed_date_id"
                    android:drawableLeft="@drawable/date"

                    android:drawableRight="@drawable/date"
                    android:inputType="date"
                    android:hint="@string/mg_fragment_register_hint_persional_id_date"/>
                <EditText
                    android:layout_width="match_parent"
                    android:paddingRight="50dp"
                    android:minHeight="66dp"
                    android:maxLines="3"
                    android:minLines="3"
                    android:lines="3"
                    android:ems="3"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_edittext_input"
                    android:singleLine="true"
                    android:id="@+id/mg_fragment_sync_ed_address"
                    android:drawableLeft="@drawable/map"
                    android:imeOptions="actionDone"
                    android:inputType="textCapSentences|textImeMultiLine"
                    android:scrollHorizontally="true"
                    android:maxLength="600"
                    android:scrollbars="vertical"

                    android:hint="@string/mg_fragment_register_hint_address"/>
                </LinearLayout>
                <TextView
                    android:background="@drawable/mg_bg_button_register_selector"
                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_main_button"
                    android:textColor="@color/colorBackground"
                    android:textAllCaps="true"
                    android:text="@string/mg_fragment_sync_action_sync"
                    android:id="@+id/mg_fragment_sync_tv_sync"
                />
                <TextView
