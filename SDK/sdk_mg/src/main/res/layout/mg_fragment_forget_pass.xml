    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_marginLeft="@dimen/mg_padding_left_right_content"
        android:layout_marginRight="@dimen/mg_padding_left_right_content"
        android:layout_below="@+id/mg_fragment_foget_pass_top_bar"
        android:layout_width="match_parent"
        android:foregroundGravity="bottom"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/fragment_forget_pass_ll_input"

            android:paddingLeft="@dimen/padding_left_right_input"
            android:paddingRight="@dimen/padding_left_right_input"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            >
<!--            <ImageView-->
<!--                android:visibility="invisible"-->
<!--                android:layout_margin="4dp"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="@dimen/migamesdk_height_logo_gg"-->
<!--                android:scaleType="fitCenter"-->
<!--                android:src="@drawable/migamesdk_logo_gg"-->
<!--                android:layout_gravity="center"-->
<!--                android:id="@+id/fragment_forget_pass_iv_logo"-->
<!--                />-->

            <TextView
                android:layout_gravity="center"
                android:textStyle="italic|bold"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTitle"
                android:text="@string/mg_text_account_or_email"
                />
            <EditText
                android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                android:paddingRight="50dp"
                style="@style/item_edittext_input"
                android:id="@+id/mg_fragment_forget_pass_ed_email"
                android:drawableLeft="@drawable/user"
                android:hint="@string/mg_text_hint_account_or_email"

                android:drawablePadding="5dp"
                />

                <TextView

                    android:layout_marginTop="@dimen/mg_spacing_edittext_input"
                    style="@style/item_main_button"
                    android:background="@drawable/mg_bg_button_register_selector"
                    android:text="@string/mg_text_confirm"
                    android:textColor="@color/colorBackground"
                    android:id="@+id/fragment_forget_pass_submit"
                />
            <LinearLayout
                android:layout_marginTop="@dimen/mg_spacing_button_main"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/mg_fragment_forget_pass_tv_login"
                    style="@style/text_title_medium"
                    android:text="@string/mg_text_forget_pass_login"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/black_overlay"
                    />

                <TextView
                    android:id="@+id/mg_fragment_forget_pass_tv_register"
                    style="@style/text_title_medium"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:textStyle="bold"
                    android:text="@string/mg_text_forget_pass_register"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/black_overlay"
                    />
            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
