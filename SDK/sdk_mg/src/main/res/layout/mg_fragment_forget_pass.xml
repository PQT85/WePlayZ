<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mg_bg_radius"
    >
    <include layout="@layout/mg_fragment_layout_back" android:id="@+id/mg_fragment_forget_pass_ll_back"/>
    <LinearLayout
        android:paddingLeft="@dimen/mg_padding_left_right_content"
        android:paddingRight="@dimen/mg_padding_left_right_content"
        android:layout_below="@+id/mg_fragment_forget_pass_ll_back"
        android:id="@+id/mg_fragment_foget_pass_top_bar"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
<!--        <ImageView-->
<!--            android:padding="6dp"-->
<!--            android:layout_width="40dp"-->
